# --- Database ---------------------------------------------------------
# PostgreSQL connection string (Railway, Supabase, RDS, etc.)
DATABASE_URL="postgresql://user:password@host:5432/sitesync?schema=public"

# --- Auth ---------------------------------------------------------------
# 32+ char random secret used to sign admin session JWTs.
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Base URL the app is served from (used to build absolute poll links in
# emails and to enforce cookie security in production).
APP_URL="http://localhost:3000"

# --- Email (optional, for invitations/reminders) ------------------------
# Provider used by src/lib/mailer.ts. Choose "resend" or "smtp".
EMAIL_PROVIDER="resend"

# Required if EMAIL_PROVIDER=resend
RESEND_API_KEY=""
EMAIL_FROM="SiteSync <scheduling@yourcompany.com>"

# Required if EMAIL_PROVIDER=smtp
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# --- Anti-abuse (optional) ----------------------------------------------
# Cloudflare Turnstile / hCaptcha site+secret keys. Leave blank to disable
# CAPTCHA (poll.captchaEnabled toggles per-poll; rate limiting still applies
# even without these set).
CAPTCHA_SITE_KEY=""
CAPTCHA_SECRET_KEY=""

# --- Calendar integrations (nice-to-have, not required for MVP) ---------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
